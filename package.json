{
	"name": "expense-manager",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:check": "drizzle-kit check",
		"wrangler:dev": "vite build && wrangler dev"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "latest",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/language-server": "latest",
		"@tailwindcss/vite": "^4.2.2",
		"@trivago/prettier-plugin-sort-imports": "latest",
		"@types/luxon": "^3.7.1",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "latest",
		"prettier-plugin-tailwindcss": "latest",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-language-server": "latest",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"typescript-svelte-plugin": "latest",
		"vite": "^8.0.8",
		"wrangler": "latest"
	},
	"dependencies": {
		"@auth/sveltekit": "^1.11.2",
		"@libsql/client": "^0.17.2",
		"@lucide/svelte": "latest",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"ag-charts-community": "^13.2.1",
		"ag-grid-community": "^35.2.1",
		"ag-grid-enterprise": "^35.2.1",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"luxon": "^3.7.2",
		"zod": "^4.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
