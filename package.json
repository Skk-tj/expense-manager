{
	"name": "expense-manager",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "oxfmt",
		"lint": "oxfmt --check && eslint .",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:check": "drizzle-kit check",
		"wrangler:dev": "vite build && wrangler dev"
	},
	"dependencies": {
		"@auth/sveltekit": "^1.11.3",
		"@libsql/client": "^0.17.4",
		"@lucide/svelte": "latest",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"ag-charts-community": "^14.0.1",
		"ag-grid-community": "^36.0.1",
		"ag-grid-enterprise": "^36.0.1",
		"drizzle-orm": "^0.45.2",
		"luxon": "^3.7.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260721.1",
		"@eslint/js": "^10.0.1",
		"@skeletonlabs/skeleton": "5.0.0",
		"@skeletonlabs/skeleton-svelte": "5.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/language-server": "latest",
		"@tailwindcss/vite": "^4.3.3",
		"@types/luxon": "^3.7.2",
		"@types/node": "^26.1.1",
		"@typescript-eslint/eslint-plugin": "^8.65.0",
		"@typescript-eslint/parser": "^8.65.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.7.0",
		"eslint-plugin-svelte": "^3.22.0",
		"globals": "^17.7.0",
		"oxfmt": "^0.59.0",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"svelte-language-server": "latest",
		"tailwindcss": "^4.3.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.65.0",
		"typescript-svelte-plugin": "latest",
		"vite": "^8.1.5",
		"wrangler": "latest"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
